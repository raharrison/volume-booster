{
   "action": {
      "default_icon": {
         "19": "icons/icon.png",
         "38": "icons/icon.png"
      },
      "default_title": "Volume Booster"
   },
   "background": {
      "service_worker": "js/background.js"
   },
   "description": "Boost your browser tab volume beyond 100% using the Web Audio API.",
   "host_permissions": [ "<all_urls>" ],
   "icons": {
      "128": "icons/icon.png",
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png"
   },
   "manifest_version": 3,
   "name": "Volume Booster",
   "permissions": [ "tabCapture", "storage", "system.display" ],
   "version": "1.0.2"
}
