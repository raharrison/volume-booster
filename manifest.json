{
   "action": {
      "default_icon": {
         "19": "image/icon.png",
         "38": "image/icon.png"
      },
      "default_title": "Volume Booster"
   },
   "background": {
      "service_worker": "js/bg.js"
   },
   "content_scripts": [ {
      "css": [ "css/app.css" ],
      "js": [ "js/content.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_start"
   } ],
   "description": "Boost your browser tab volume beyond 100% using the Web Audio API.",
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "image/icon.png",
      "16": "image/icon.png",
      "32": "image/icon.png",
      "48": "image/icon.png"
   },
   "manifest_version": 3,
   "name": "Volume Booster",
   "permissions": [ "tabCapture", "storage", "system.display" ],
   "version": "1.1.10"
}
